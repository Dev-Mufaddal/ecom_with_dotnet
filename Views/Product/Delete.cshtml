@model Authentication.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<h2>Delete Product</h2>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this product?</h4>
    <p class="mb-0">This action cannot be undone.</p>
</div>

<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <p>@Model.Description</p>

        <div class="row mt-3">
            <div class="col-md-6">
                <p><strong>Price:</strong> $@Model.Price.ToString("F2")</p>
                <p><strong>Category:</strong> @Model.Category</p>
            </div>
            <div class="col-md-6">
                <p><strong>Stock:</strong> @Model.StockQuantity</p>
                <p><strong>Created:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mt-3">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height: 200px;" />
            </div>
        }
    </div>
</div>

<form asp-action="Delete" class="mt-4">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">
        <i class="fas fa-trash"></i> Delete Permanently
    </button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>