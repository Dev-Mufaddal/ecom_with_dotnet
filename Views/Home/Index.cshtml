@{
    ViewData["Title"] = "Welcome to Our Store";
}

<div class="text-center">
    <h1 class="display-4">Welcome!</h1>
    <p>Discover amazing products at great prices.</p>

    <div class="mt-5">
        <a asp-controller="Product" asp-action="Index"
           class="btn btn-primary btn-lg">
            Browse All Products
        </a>

        @if (User.Identity.IsAuthenticated)
        {
            @* <a asp-controller="Orders" asp-action="AdminDashboard"
               class="btn btn-success btn-lg ml-3">
                My Dashboard
            </a> *@
        }
        else
        {
            <a asp-controller="Account" asp-action="Login"
               class="btn btn-outline-primary btn-lg ml-3">
                Login
            </a>
            <a asp-controller="Account" asp-action="Register"
               class="btn btn-secondary btn-lg ml-3">
                Register
            </a>
        }
    </div>

    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">🛒 Wide Selection</h5>
                    <p class="card-text">Browse through hundreds of products in various categories.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">⚡ Fast Delivery</h5>
                    <p class="card-text">Get your products delivered quickly and securely.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">🔒 Secure Shopping</h5>
                    <p class="card-text">Shop with confidence with our secure payment system.</p>
                </div>
            </div>
        </div>
    </div>
</div>