<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Authentication</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Authentication.styles.css" asp-append-version="true" />
    <!-- Include Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" asp-append-version="true" />
</head>
<body id="themeBody">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Authentication</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <button id="themeToggle" class="btn btn-sm btn-outline-secondary ms-3">
                            🌙
                        </button>

                        <!-- FIXED: Changed from Home to Product controller -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Product" asp-action="Index">Products</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="contact">Contact</a>
                        </li>

                        <li class="nav-item">
                            @await Component.InvokeAsync("CartCount")
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Orders"
                                   asp-action="MyOrders">
                                    My Orders
                                </a>
                            </li>
                        }



                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- Add Admin Create link if user is admin -->
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Product" asp-action="Create">
                                        <i class="fas fa-plus"></i> Add Product
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Orders" asp-action="AdminDashboard">
                                        Admin dashboard
                                    </a>
                                </li>
                            }

                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-link nav-link text-dark">Logout</button>
                            </form>

                            <li class="nav-item">
                                <span class="nav-link text-dark">Welcome: @User.Identity.Name</span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" data-bs-toggle="collapse" href="#userInfoCollapse"
                                   role="button" aria-expanded="false" aria-controls="userInfoCollapse">
                                    <i class="fas fa-user"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Account"
                                   asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Account"
                                   asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        @if (User.Identity.IsAuthenticated)
        {
            <div class="collapse" id="userInfoCollapse">
                <div class="card card-body">
                    <ul class="list-unstyled">
                        <li>Username: @User.Identity.Name</li>
                        <li>Email: Email id is confidential</li>
                        <li>Password: ***********</li>
                    </ul>
                </div>
            </div>
        }
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* <footer class="footer footer-minimal">
        <div class="container">
            <div class="footer-main">
                <div class="footer-brand">

                    <p>&copy; 2024 Authentication. Built with ❤️</p>
                </div>
            </div>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true" /></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true" /></script>
    <script src="~/js/site.js" asp-append-version="true" /></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>