<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-commerce Features</title>
    <link rel="stylesheet" href="/css/features.css" />
</head>
<body>
    <div class="container">
        <div class="header">
            <h1 class="main-title">Platform Features</h1>
            <p class="subtitle">Explore the powerful capabilities designed to elevate your e-commerce experience</p>
        </div>

        <div class="divider"></div>

        <h2 class="section-title">🛍️ Shopping & User Experience</h2>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-item">
                    <span class="feature-label">Product Catalog</span>
                    <div class="feature-desc">Browse products by category, brand, price range with advanced filtering</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">Available on all devices</span>
                    </div>
                    <div class="feature-status">Active</div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Advanced Search</span>
                    <div class="feature-desc">Smart search with filters for price, rating, color, size, and brand</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">Real-time results</span>
                    </div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Wishlist System</span>
                    <div class="feature-desc">Save favorite products and create personalized collections</div>
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-item">
                    <span class="feature-label">Shopping Cart</span>
                    <div class="feature-desc">Add/remove items, modify quantities, and save cart for later use</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">Auto-save feature</span>
                    </div>
                    <div class="feature-status">Active</div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Product Reviews</span>
                    <div class="feature-desc">Read and write customer reviews with photo uploads</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">Verified purchases only</span>
                    </div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Product Comparisons</span>
                    <div class="feature-desc">Side-by-side comparison of product features and specifications</div>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <h2 class="section-title">💳 Checkout & Payment System</h2>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-item">
                    <span class="feature-label">Secure Checkout</span>
                    <div class="feature-desc">Multi-step checkout with guest option and saved addresses</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">SSL encrypted</span>
                    </div>
                    <div class="feature-status">Active</div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Multiple Payment Options</span>
                    <div class="feature-desc">Credit/debit cards, PayPal, digital wallets, bank transfers, COD</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">PCI compliant</span>
                    </div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Shipping Integration</span>
                    <div class="feature-desc">Real-time rates from major carriers with tracking</div>
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-item">
                    <span class="feature-label">Order Tracking</span>
                    <div class="feature-desc">Real-time shipping updates with delivery notifications</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">Mobile notifications</span>
                    </div>
                    <div class="feature-status">Active</div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Address Management</span>
                    <div class="feature-desc">Save multiple shipping addresses and set default options</div>
                </div>

                <div class="feature-item">
                    <span class="feature-label">Tax Calculation</span>
                    <div class="feature-desc">Automatic tax calculation based on location and product type</div>
                    <div class="checkbox-container">
                        <div class="checkbox checked"></div>
                        <span class="checkbox-label">Real-time updates</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <!-- Clean CTA Section like your screenshot -->
        <div class="cta-section">
            <h2 class="cta-title">Start Your E-commerce Journey</h2>
            <p class="cta-subtitle">Create your store and unlock all these powerful features for your business</p>

            <!-- 4 Steps Grid -->
            <div class="steps-container">
                <div class="step">
                    <div class="step-number">1</div>
                    <div class="step-title">Sign Up</div>
                    <div class="step-desc">Create your account in minutes</div>
                </div>

                <div class="step">
                    <div class="step-number">2</div>
                    <div class="step-title">Set Up Store</div>
                    <div class="step-desc">Customize your storefront and add products</div>
                </div>

                <div class="step">
                    <div class="step-number">3</div>
                    <div class="step-title">Configure</div>
                    <div class="step-desc">Set up payments, shipping, and taxes</div>
                </div>

                <div class="step">
                    <div class="step-number">4</div>
                    <div class="step-title">Launch</div>
                    <div class="step-desc">Go live and start selling to customers</div>
                </div>
            </div>

            @*<!-- Privacy Footer -->
            <div class="privacy-footer">
                <div class="privacy-links">
                    <a href="#">Privacy</a> |
                    <a href="#">Terms</a> |
                    <a href="#">Cookies</a>
                </div>
                <div class="copyright">
                    © 2023 E-commerce Platform. All rights reserved.
                </div>
            </div>*@
        </div>
    </div>
</body>
</html>